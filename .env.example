# ── Who this is for ──────────────────────────────────────────
GIRL_NAME=Aimaral

# ── Database ─────────────────────────────────────────────────
# Local dev (Postgres on your machine). docker-compose overrides this
# automatically to point at the "db" container.
DATABASE_URL=postgresql+psycopg2://oneshot:oneshot@localhost:5432/oneshot

# Used by docker-compose to provision the Postgres container:
POSTGRES_USER=oneshot
POSTGRES_PASSWORD=oneshot
POSTGRES_DB=oneshot

# ── Telegram notifications ───────────────────────────────────
# 1. Create a bot with @BotFather -> get the token.
# 2. Send your bot a message, then read your chat id from @userinfobot.
# Leave blank to run without Telegram (answers still get stored in the DB).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Admin panel (/admin) ─────────────────────────────────────
# These seed the admin login on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-now
# Long random string used to sign admin session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-string
